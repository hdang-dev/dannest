# Copy this file to `terraform.tfvars` and fill in real values.
# terraform.tfvars is gitignored — NEVER commit real secrets.

render_api_key  = "rnd_xxxxxxxxxxxxxxxxxxxx"
render_owner_id = "tea-xxxxxxxxxxxxxxxxxxxx"

db_url      = "jdbc:postgresql://YOUR-NEON-HOST/neondb?sslmode=require"
db_user     = "neondb_owner"
db_password = "npg_xxxxxxxxxxxxxx"

# Generate with: openssl rand -hex 48
jwt_secret = "your-long-random-secret"

# ---- Cloudflare R2 (media storage) ----
# Same values as service/src/main/resources/application-local.yml.
r2_account_id      = "your32charhexaccountid"
r2_access_key      = "your_access_key_id"
r2_secret_key      = "your_secret_access_key"
r2_bucket          = "dannest-media"
r2_public_base_url = "https://pub-xxxx.r2.dev"
